<header>
    <div class="header-top">
        <a href="/" class="site-title">kitan's space travel</a>
        <div class="header-controls">
            <label class="header-toggle">
                <input type="checkbox" id="dm" /> dark mode
            </label>
            <label class="header-toggle">
                <input type="checkbox" id="mono-toggle" /> mono font
            </label>
        </div>
    </div>
    <div class="separator">--- ✿ ---</div>
    <nav>
        <a href="/music">Music</a>
        <a href="/art">Art</a>
        <a href="/code">Coding</a>
        <a href="/archive">Archive</a>
    </nav>
</header>
<script>
    const html = document.documentElement;

    const dm = document.getElementById("dm");
    if (!dm) throw new Error("dark mode toggle not found");
    if (localStorage.getItem("dark") === "1") {
        html.classList.add("dark");
        dm.checked = true;
    }
    dm.addEventListener("change", () => {
        html.classList.toggle("dark", dm.checked);
        localStorage.setItem("dark", dm.checked ? "1" : "0");
    });

    const monoToggle = document.getElementById("mono-toggle");
    if (!monoToggle) throw new Error("mono font toggle not found");
    if (localStorage.getItem("mono") === "1") {
        html.classList.add("mono");
        monoToggle.checked = true;
    }
    monoToggle.addEventListener("change", () => {
        html.classList.toggle("mono", monoToggle.checked);
        localStorage.setItem("mono", monoToggle.checked ? "1" : "0");
    });
</script>
