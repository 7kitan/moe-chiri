---
import type { CollectionEntry } from 'astro:content';

type Post = CollectionEntry<'blog'>;

interface Props {
  posts: Post[];
}

function formatDate(date: Date) {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, "0");
  const d = String(date.getDate()).padStart(2, "0");
  return `${y}.${m}.${d}`;
}

const { posts } = Astro.props;
---

<ul class="post-list">
  {
    posts.map((post) => (
      <li>
        <a href={`/blog/${post.id}/`}>
          <span class="post-title">{post.data.title}</span>
          <div class="post-dot"></div>
          <span class="post-date">{formatDate(post.data.pubDate)}</span>
        </a>
      </li>
    ))
  }
</ul>

<style>
  .post-list {
    padding: 0;
    margin: 0;
    list-style: none;
  }
  .post-list a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0;
    text-decoration: none;
  }
  .post-list a:hover .post-title {
    color: var(--a);
  }
  .post-title {
    font-size: var(--fs);
    color: var(--t);
    transition: color 0.12s;
  }
  .post-dot {
    flex: 1 1 auto;
    min-width: 2rem;
    height: 0.5px;
    background: var(--b);
  }
  .post-date {
    font-family: var(--m);
    font-size: 0.75rem;
    color: var(--ts);
    flex-shrink: 0;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  @media (max-width: 480px) {
    .post-list a {
      flex-wrap: wrap;
      gap: 0.15rem;
    }
    .post-title {
      overflow: visible;
      text-overflow: clip;
      white-space: normal;
      flex-basis: 100%;
    }
    .post-dot {
      display: none;
    }
    .post-date {
      font-size: 0.6875rem;
    }
  }
</style>
