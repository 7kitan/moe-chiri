<button class="theme-toggle" id="dm">☾</button>
<script>
  const dm = document.getElementById("dm");
  if (!dm) throw new Error("theme toggle not found");
  const h = document.documentElement;
  if (localStorage.getItem("dark") === "1") h.classList.add("dark");
  dm.textContent = h.classList.contains("dark") ? "☀" : "☾";
  function toggle() {
    h.classList.toggle("dark");
    dm.textContent = h.classList.contains("dark") ? "☀" : "☾";
    localStorage.setItem("dark", h.classList.contains("dark") ? "1" : "0");
  }
  dm.addEventListener("click", toggle);
</script>
