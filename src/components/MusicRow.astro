---
interface Link {
  label: string;
  url: string;
}

interface Props {
  title: string;
  year: string;
  image?: string;
  links: Link[];
}

const { title, year, image = "/placeholder.svg", links } = Astro.props;
---

<div class="music-row">
  <img src={image} alt={title} loading="lazy" />
  <div class="music-body">
    <div class="music-title">{title}</div>
    <div class="music-year">{year}</div>
    <div class="music-links">
      {links.map((link) => <a href={link.url}>{link.label}</a>)}
    </div>
  </div>
</div>

<style>
  .music-row {
    display: flex;
    gap: 1rem;
    align-items: center;
    padding: 0.5rem 0;
  }
  .music-row img {
    width: 50%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 4px;
    display: block;
    background: var(--b);
  }
  .music-body {
    flex: 1;
  }
  .music-title {
    font-family: var(--m);
    font-size: var(--fs);
    font-weight: var(--fw-b);
    color: var(--t);
    margin: 0 0 0.1rem;
  }
  .music-year {
    font-family: var(--m);
    font-size: 0.6875rem;
    color: var(--ts);
  }
  .music-links {
    margin-top: 0.25rem;
  }
  .music-links a {
    font-family: var(--m);
    font-size: 0.625rem;
    color: var(--ts);
    text-decoration: none;
    padding: 0;
    display: inline;
  }
  .music-links a:hover {
    color: var(--a);
  }
</style>
