---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import MusicRow from "../components/MusicRow.astro";
import PostList from "../components/PostList.astro";
import { SITE_DESCRIPTION } from "../consts";

const musicEntries = (await getCollection("music")).slice(0, 3);
const posts = (await getCollection("blog"))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 6);
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title="Kitan — Moe-Chiri" description={SITE_DESCRIPTION} />
    </head>
    <body>
        <Header />
        <br />

        <section class="bio">
            <p>
                Hi, I put my stuff here. You can contact me on <a
                    href="https://bsky.app/profile/kitan.moe">Bluesky</a
                >.
            </p>
        </section>

        {
            musicEntries.length > 0 && (
                <section class="section">
                    <h2>✿ Music</h2>
                    <div class="music-list">
                        {musicEntries.map((entry) => (
                            <MusicRow
                                title={entry.data.title}
                                year={entry.data.year}
                                image={entry.data.image}
                                links={entry.data.links}
                            />
                        ))}
                    </div>
                    <p style="margin-top: 0.25rem; font-family: var(--m); font-size: 0.75rem;">
                        <a href="/music">View all →</a>
                    </p>
                </section>
            )
        }

        <section class="section" id="blog">
            <h2>✿ Blog</h2>
            <PostList posts={posts} />
            <p
                style="margin-top: 0.5rem; font-family: var(--m); font-size: 0.75rem;"
            >
                <a href="/archive">View all →</a>
            </p>
        </section>

        <Footer />
        <ThemeToggle />
    </body>
</html>

<style>
    .bio p {
        margin: 0 0 0.75em;
    }
    .bio p:last-child {
        margin: 0;
    }
    .music-list {
        display: grid;
        gap: 0.5rem;
    }
</style>
