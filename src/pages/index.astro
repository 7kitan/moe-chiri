---
import { getCollection } from "astro:content";
import BasePage from "../layouts/BasePage.astro";
import MusicRow from "../components/MusicRow.astro";
import PostList from "../components/PostList.astro";
import { SITE_DESCRIPTION } from "../consts";

const musicEntries = (await getCollection("music")).slice(0, 3);
const posts = (await getCollection("blog"))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 6);
---

<BasePage title="kitan's space travel" description={SITE_DESCRIPTION}>
    <br />

    <section class="bio">
        <p>
            Hi, I put my stuff here. You can contact me on <a
                href="https://bsky.app/profile/kitan.moe">Bluesky</a
            >.
        </p>
        <p>
            Use <a href="https://kitan.moe/rss.xml ">this xml link</a> to add the
            blog to a RSS feed.
        </p>
    </section>

    {
        musicEntries.length > 0 && (
            <section class="section">
                <h2>✿ Music</h2>
                <div class="music-list">
                    {musicEntries.map((entry) => (
                        <MusicRow
                            title={entry.data.title}
                            year={entry.data.year}
                            image={entry.data.image}
                            links={entry.data.links}
                        />
                    ))}
                </div>
                <p style="margin-top: 0.25rem; font-family: var(--m); font-size: 0.75rem;">
                    <a href="/music">View all →</a>
                </p>
            </section>
        )
    }

    <section class="section" id="blog">
        <h2>✿ Posts</h2>
        <PostList posts={posts} />
        <p
            style="margin-top: 0.5rem; font-family: var(--m); font-size: 0.75rem;"
        >
            <a href="/archive">View all →</a>
        </p>
    </section>
</BasePage>

<style>
    .bio p {
        margin: 0 0 0.75em;
    }
    .bio p:last-child {
        margin: 0;
    }
    .music-list {
        display: grid;
        gap: 0.5rem;
    }
</style>
