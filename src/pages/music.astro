---
import { getCollection } from "astro:content";
import BasePage from "../layouts/BasePage.astro";

const releases = await getCollection("music");
---

<BasePage title="Music — Kitan">
    <h1>Music</h1>
    <div class="about">
        <p>Sure would like to make some Vocaloid...</p>
    </div>

    {
        releases.length > 0 ? (
            releases.map((release) => (
                <div class="release">
                    <div class="entry">
                        {release.data.embedUrl && (
                            <div class="video">
                                <iframe
                                    src={release.data.embedUrl}
                                    title={release.data.title}
                                    allow="fullscreen"
                                    loading="lazy"
                                />
                            </div>
                        )}
                        <div class="body">
                            <div class="title">{release.data.title}</div>
                            <div class="meta">{release.data.year}</div>
                            <div class="links">
                                {release.data.links.map((link) => (
                                    <a href={link.url}>{link.label}</a>
                                ))}
                            </div>
                        </div>
                    </div>
                </div>
            ))
        ) : (
            <p>Nothing here yet!</p>
        )
    }
</BasePage>

<style>
    .release {
        border-top: 1px solid var(--b);
    }
    .release + .release {
        border-top: none;
    }
    .entry {
        padding: 1.25rem 0;
    }
    .video {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
        overflow: hidden;
        border-radius: 6px;
        margin: 0 0 0.75rem;
    }
    .video iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }
    .entry .title {
        font-family: var(--m);
        font-size: var(--fs);
        font-weight: var(--fw-b);
        color: var(--t);
        margin: 0 0 0.15rem;
    }
    .entry .meta {
        font-family: var(--m);
        font-size: var(--fs-sm);
        color: var(--a);
        margin: 0 0 0.3rem;
    }
    .entry p {
        margin: 0 0 0.3rem;
        font-size: var(--fs);
    }
    .entry .links {
        margin: 0.4rem 0 0;
    }
    .entry .links a {
        font-family: var(--m);
        font-size: var(--fs-sm);
        color: var(--ts);
        text-decoration: none;
        margin-right: 0.75rem;
    }
    .entry .links a:hover {
        color: var(--a);
    }
</style>
